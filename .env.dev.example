# Copy this file to .env.dev before running make targets.
# cp .env.dev.example .env.dev

# PostgreSQL settings for the dev environment (compose.dev.yaml).
POSTGRES_DB=template_ai_dev
POSTGRES_USER=template_ai_dev
POSTGRES_PASSWORD=template_ai_dev

# AI model selection (OpenRouter). Override via apps/api/.env
AI_MODEL=deepseek/deepseek-v4-flash:free
AI_MODEL_FALLBACK=google/gemma-4-31b-it:free
