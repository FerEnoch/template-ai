{
  "name": "@template-ai/api",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "db:migrate": "node --experimental-strip-types ./src/infrastructure/postgres/migrate.ts",
    "db:migrate:validate": "node --experimental-strip-types ./src/infrastructure/postgres/validate-domain-schema-first.ts",
    "test": "vitest run",
    "lint": "pnpm run typecheck",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@template-ai/contracts": "workspace:*",
    "dotenv": "^17.4.2",
    "multer": "^2.1.1",
    "openai": "^6.39.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  }
}
