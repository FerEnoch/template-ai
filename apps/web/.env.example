# API backend URL for Next.js rewrites proxy (server-side)
# Defaults to same-origin for production; set to http://localhost:3001 for local dev
API_BASE_URL=http://localhost:3001

# Client-side API base URL (used by MSW / browser code)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Enable MSW mock service layer (intercepts API calls in the browser)
NEXT_PUBLIC_MSW=true
