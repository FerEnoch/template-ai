# Copy this file to .env.test before running make targets.
# cp .env.test.example .env.test

# PostgreSQL settings for the test environment (compose.test.yaml).
POSTGRES_DB=template_ai_test
POSTGRES_USER=template_ai_test
POSTGRES_PASSWORD=template_ai_test

# AI model selection (OpenRouter).
AI_MODEL=deepseek/deepseek-v4-flash:free
AI_MODEL_FALLBACK=google/gemma-4-31b-it:free

# Redis for BullMQ job queues (async analysis workers).
REDIS_HOST=localhost
REDIS_PORT=6379
